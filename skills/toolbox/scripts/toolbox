#!/bin/bash
set -euo pipefail

IMAGE="claude-toolbox"

# オプションを収集
COMMIT=false
ROOT=false
DOCKER_OPTS=()
DIR_COUNT=0
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --dir)
      shift
      DIR_PATH="${1:?--dir にはパスを指定してください}"
      if [[ ! -d "$DIR_PATH" ]]; then
        echo "エラー: ディレクトリが存在しません: $DIR_PATH" >&2
        exit 1
      fi
      DIR_COUNT=$((DIR_COUNT + 1))
      DOCKER_OPTS+=(-v "$DIR_PATH:/work/dir${DIR_COUNT}")
      shift
      ;;
    --root)
      ROOT=true
      shift
      ;;
    --commit)
      COMMIT=true
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [[ "$ROOT" == false ]]; then
  DOCKER_OPTS+=(--user "$(id -u):$(id -g)")
fi

if [[ "$COMMIT" == true ]]; then
  CONTAINER="toolbox-$(head -c8 /dev/urandom | od -An -tx1 | tr -d ' \n')"
  trap 'docker rm "$CONTAINER" 2>/dev/null' EXIT
  docker run --name "$CONTAINER" -v "$(pwd):/work/pwd" "${DOCKER_OPTS[@]}" "$IMAGE" "$@"
  docker commit "$CONTAINER" "$IMAGE"
else
  docker run --rm -i -v "$(pwd):/work/pwd" "${DOCKER_OPTS[@]}" "$IMAGE" "$@"
fi
