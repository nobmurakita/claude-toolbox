#!/bin/bash
set -euo pipefail

IMAGE="claude-toolbox"

# Docker の起動確認
if ! docker info >/dev/null 2>&1; then
  echo "エラー: Docker が起動していません。Docker を起動してから再実行してください。" >&2
  exit 1
fi

# オプションを収集
COMMIT=false
ROOT=false
DOCKER_OPTS=()
DIR_COUNT=0
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --dir)
      shift
      DIR_PATH="${1:?--dir にはパスを指定してください}"
      if [[ ! -d "$DIR_PATH" ]]; then
        echo "エラー: ディレクトリが存在しません: $DIR_PATH" >&2
        exit 1
      fi
      DIR_COUNT=$((DIR_COUNT + 1))
      DOCKER_OPTS+=(-v "$DIR_PATH:/work/dir${DIR_COUNT}")
      shift
      ;;
    --root)
      ROOT=true
      shift
      ;;
    --commit)
      COMMIT=true
      shift
      ;;
    --memory)
      shift
      MEMORY="${1:?--memory にはサイズを指定してください (例: 4g, 512m)}"
      DOCKER_OPTS+=(--memory "$MEMORY")
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      echo "エラー: 不明なオプション: $1" >&2
      exit 1
      ;;
  esac
done

if [[ "$ROOT" == false ]]; then
  DOCKER_OPTS+=(--user "$(id -u):$(id -g)")
fi

if [[ "$COMMIT" == true ]]; then
  CONTAINER="toolbox-$(head -c8 /dev/urandom | od -An -tx1 | tr -d ' \n')"
  trap 'docker rm "$CONTAINER" 2>/dev/null' EXIT
  if docker run -i --name "$CONTAINER" -v "$(pwd):/work/pwd" ${DOCKER_OPTS[@]+"${DOCKER_OPTS[@]}"} "$IMAGE" "$@"; then
    docker commit "$CONTAINER" "$IMAGE"
  else
    echo "エラー: コマンドが失敗したためイメージを更新しません" >&2
    exit 1
  fi
else
  docker run --rm -i -v "$(pwd):/work/pwd" ${DOCKER_OPTS[@]+"${DOCKER_OPTS[@]}"} "$IMAGE" "$@"
fi
